# PostgreSQL
POSTGRES_PASSWORD=changeme

# JWT (최소 32자 랜덤 문자열, openssl rand -base64 48 로 생성 추천)
JWT_SECRET=replace-with-random-32-plus-character-string-from-openssl

# NextAuth (web 패키지용, JWT_SECRET와 다른 값)
AUTH_SECRET=replace-with-another-random-32-plus-character-string

# 셀프호스팅 시 외부에서 접근 가능한 URL
WEB_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:3001
