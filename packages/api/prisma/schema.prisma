// mytool — Prisma schema
//
// DATABASE_URL: 런타임용 (Supabase Supavisor pooler, port 6543)
// DIRECT_URL: 마이그레이션 전용 (Supabase direct connection, port 5432)
// 자체호스팅 시 DIRECT_URL을 생략하면 DATABASE_URL만 사용.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// 인증 / 조직
// ============================================================

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  name         String?
  avatarUrl    String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  memberships  OrgMembership[]
  tokens       CliToken[]
  sessions     ClaudeSession[]
  events       Event[]
  usageRecords UsageRecord[]
  devices      Device[]

  @@map("users")
}

enum Role {
  OWNER
  MEMBER
}

model Organization {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  members   OrgMembership[]
  projects  Project[]
  snapshots SyncSnapshot[]
  syncJobs  SyncJob[]

  @@map("organizations")
}

model OrgMembership {
  id        String       @id @default(cuid())
  userId    String
  orgId     String
  role      Role         @default(MEMBER)
  createdAt DateTime     @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId])
  @@map("org_memberships")
}

/// 토큰의 용도 — Web 세션은 7일, CLI 토큰은 1년 유효.
enum TokenKind {
  WEB
  CLI
}

model CliToken {
  id         String     @id @default(cuid())
  userId     String
  /// SHA-256(jwt) — 평문 토큰은 저장하지 않음
  tokenHash  String     @unique
  /// Web 세션 / CLI 토큰 구분
  kind       TokenKind  @default(WEB)
  /// 사용자 표시용 라벨
  label      String?
  /// 토큰이 마지막으로 사용된 시각 (분 단위로 throttle)
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime   @default(now())
  expiresAt  DateTime
  /// PR 3 — 이 토큰을 발급받은 device 와의 연결 (sync push/pull 권한 매핑)
  /// 기존 토큰 호환을 위해 nullable. 새 `mytool sync push` 가 필요시 device 자동 생성·연결.
  deviceId   String?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  device Device? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, revokedAt])
  @@index([deviceId])
  @@map("cli_tokens")
}

// ============================================================
// PR 3 — Sync (push/pull 모델, B 안)
// ============================================================

/// 사용자가 mytool 을 사용하는 PC 단위 식별자.
/// 한 사용자가 여러 PC (회사·집·서버 등) 를 쓰는 시나리오를 자연스럽게 지원.
/// `mytool sync push` 첫 실행 시 자동 생성됨.
model Device {
  id         String   @id @default(cuid())
  userId     String
  /// 사용자 지정 별명 (예: "desk-home"). 미지정 시 hostname 사용.
  name       String
  hostname   String
  /// "darwin" | "linux" | "win32" 등 process.platform 값
  platform   String
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokens    CliToken[]
  snapshots SyncSnapshot[] @relation("DeviceSnapshots")
  // 이 device 가 target 인 sync job 들
  inboundJobs SyncJob[]    @relation("TargetDevice")

  @@unique([userId, name])
  @@index([userId])
  @@map("devices")
}

/// 한 시점의 device 스캔 결과. items + bundle (zip) 한 쌍.
/// bundle 본체는 BundleStorage 백엔드 (local fs / Supabase Storage) 에 저장되고
/// `bundleStorageKey` 로 참조한다. nullable 인 이유는 manifest 만 먼저 업로드되고
/// bundle 본체는 별도 multipart 요청으로 채우는 2 단계 업로드 흐름을 허용하기 위함.
model SyncSnapshot {
  id               String   @id @default(cuid())
  orgId            String
  deviceId         String
  createdBy        String   // userId — 누가 push 했는지 (보통 device.userId 와 동일)
  createdAt        DateTime @default(now())
  /// BundleStorage 가 발급한 key. local 백엔드에서는 파일 경로, supabase 에서는 object key.
  bundleStorageKey String?
  /// SyncManifest (version, items[], sourceHost, sourcePlatform, masked)
  manifest         Json
  /// 마스킹 적용 여부. manifest.masked 와 동기화. Web 에 명시 표시.
  masked           Boolean  @default(false)
  /// items.length — UI 에 빠르게 보여주기 위한 캐시.
  itemCount        Int      @default(0)

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  device Device       @relation("DeviceSnapshots", fields: [deviceId], references: [id], onDelete: Cascade)
  jobs   SyncJob[]    @relation("SourceSnapshot")

  @@index([orgId, createdAt])
  @@index([deviceId, createdAt])
  @@map("sync_snapshots")
}

/// Web 의 "복사 실행" 으로 생성된 작업. 대상 device 의 cli `sync pull` 이 폴링해서 처리.
model SyncJob {
  id                String    @id @default(cuid())
  orgId             String
  sourceSnapshotId  String
  targetDeviceId    String
  /// 대상 프로젝트 (project scope item 적용용). nullable — 전역 항목만 있으면 비움.
  targetProjectId   String?
  /// 적용할 item 의 id 목록 (manifest 의 items 배열 안에서 식별). JSON string[].
  itemIds           Json
  /// 적용 옵션. JSON: { mask?: boolean, overwrite?: 'backup'|'force'|'skip' }
  options           Json
  /// pending | running | done | failed | partial
  status            String    @default("pending")
  /// 결과 보고. JSON: { applied: string[], skipped: string[], errors: [...] }
  result            Json?
  createdBy         String
  createdAt         DateTime  @default(now())
  startedAt         DateTime?
  finishedAt        DateTime?

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  snapshot SyncSnapshot @relation("SourceSnapshot", fields: [sourceSnapshotId], references: [id], onDelete: Cascade)
  target   Device       @relation("TargetDevice", fields: [targetDeviceId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([targetDeviceId, status, createdAt])
  @@map("sync_jobs")
}

// ============================================================
// 프로젝트 / 세션 / 이벤트
// ============================================================

model Project {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// 4축 워크스페이스 토글 (integration-plan §0)
  /// Skills 축 — sync 페이지·기능 활성 여부
  syncEnabled    Boolean @default(true)
  /// Execution 축 — harness·PreToolUse 강제 활성 여부
  harnessEnabled Boolean @default(false)
  /// harness.yaml 의 캐시본 (web 에서 편집). 실제 파일은 사용자 PC.
  harnessConfig  Json?

  org          Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sessions     ClaudeSession[]
  events       Event[]
  usageRecords UsageRecord[]
  dailyStats   DailyProjectStats[]
  harnessRuns  HarnessRun[]

  @@unique([orgId, slug])
  @@map("projects")
}

model ClaudeSession {
  id        String    @id
  projectId String
  userId    String
  startedAt DateTime
  endedAt   DateTime?

  createdAt DateTime  @default(now())

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  events       Event[]
  usageRecords UsageRecord[]
  messages     Message[]

  @@index([projectId, startedAt])
  @@index([userId])
  @@map("claude_sessions")
}

model Event {
  id              String    @id @default(cuid())
  projectId       String
  sessionId       String
  userId          String

  hookEventName    String
  toolName         String?
  toolInput        String?
  toolResponse     String?
  exitCode         Int?

  isSkillCall      Boolean   @default(false)
  skillName        String?
  isAgentCall      Boolean   @default(false)
  agentType        String?
  agentDesc        String?
  isSlashCommand   Boolean   @default(false)
  slashCommandName String?
  agentId          String?

  rawPayload       Json?

  timestamp        DateTime
  createdAt        DateTime  @default(now())

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session ClaudeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId, timestamp])
  @@index([sessionId, timestamp])
  @@index([skillName])
  @@index([agentType])
  @@map("events")
}

model UsageRecord {
  id                       String   @id @default(cuid())
  projectId                String
  sessionId                String
  userId                   String

  model                    String
  inputTokens              Int
  outputTokens             Int
  cacheCreationInputTokens Int      @default(0)
  cacheReadInputTokens     Int      @default(0)
  estimatedCostUsd         Decimal  @db.Decimal(12, 6)

  isSubagent               Boolean  @default(false)
  recordedAt               DateTime
  createdAt                DateTime @default(now())

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session ClaudeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId, recordedAt])
  @@index([userId, recordedAt])
  @@map("usage_records")
}

model DailyProjectStats {
  id                  String   @id @default(cuid())
  projectId           String
  date                DateTime @db.Date

  sessionCount        Int      @default(0)
  activeUsers         Int      @default(0)
  inputTokens         BigInt   @default(0)
  outputTokens        BigInt   @default(0)
  cacheReadTokens     BigInt   @default(0)
  cacheCreationTokens BigInt   @default(0)
  estimatedCostUsd    Decimal  @default(0) @db.Decimal(14, 6)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, date])
  @@index([projectId, date])
  @@map("daily_project_stats")
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  orderIdx  Int
  timestamp DateTime
  createdAt DateTime @default(now())

  session ClaudeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, orderIdx])
  @@index([sessionId, orderIdx])
  @@map("messages")
}
// ============================================================
// PR 5 — Harness Run / Event (integration-plan §5, §6.2)
// ============================================================

/// 한 번의 `harness run` 실행을 추적. 보통 API 가 spawn 한 subprocess 가
/// reportToken 으로 인증해서 phase 전이 이벤트를 POST 한다.
/// status: running | passed | failed | aborted
model HarnessRun {
  id             String    @id @default(cuid())
  projectId      String
  /// 누가 시작했는지 (web 의 "Run" 버튼 누른 user, 또는 cli 의 user)
  startedBy      String
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  /// running | passed | failed | aborted
  status         String    @default("running")
  /// 이터레이션 카운트 — verify 통과까지 몇 번 빌드/리포트 돌았는지.
  iterations     Int       @default(0)
  /// CLI 가 events 라우트 호출 시 Bearer 로 쓰는 short-lived token.
  /// SHA-256 해시로 저장 (평문은 발급 시 1회만 응답).
  reportTokenHash String   @unique
  /// 토큰 만료. 보통 startedAt + 24h.
  reportTokenExpiresAt DateTime
  /// harness.yaml 캐시 (시작 시점). 나중에 web 에서 비교용.
  configSnapshot Json?

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events  HarnessEvent[]

  @@index([projectId, startedAt])
  @@index([status])
  @@map("harness_runs")
}

/// harness CLI 가 phase 전이마다 보내는 이벤트.
/// claude-harness 의 reporter.py payload schema 와 1:1:
///   { phase, level, ts (ISO-8601 UTC), payload }
/// phase: ideation | build | verify | report
/// level: info | warn | error
model HarnessEvent {
  id      String   @id @default(cuid())
  runId   String
  /// 이벤트 발생 시각 (reporter 가 보낸 ts). 서버 도착 시각이 아님.
  ts      DateTime
  phase   String
  level   String   @default("info")
  /// reporter 의 자유로운 payload. 예: { outcome, rolled_back_to, requirement_id, ... }
  payload Json
  /// 서버 도착 시각 (디버그용)
  createdAt DateTime @default(now())

  run HarnessRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, ts])
  @@map("harness_events")
}
